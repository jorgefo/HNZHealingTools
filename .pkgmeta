# BigWigsMods/packager config for automated releases.
# https://github.com/BigWigsMods/packager
#
# When this repo is tagged (e.g. `git tag v1.1.0 && git push --tags`), the
# GitHub Actions workflow in .github/workflows/release.yml runs the packager,
# which reads this file to know what to include and exclude, then attaches the
# resulting zip to a GitHub Release. If CurseForge / Wago / WoWInterface API
# tokens are set as repo secrets, it also uploads to those platforms.

package-as: HNZHealingTools

# IDs de los proyectos en cada plataforma. El packager los usa para subir el
# zip al proyecto correcto. Sacalos del URL/settings de cada proyecto:
#   CurseForge: pagina del proyecto -> About this Project -> Project ID (numero)
#   Wago:       Project Settings -> Wago ID (string alfanumerico)
# Descomenta y completa cuando los tengas — mientras esten comentados, esa
# plataforma se skipea silenciosamente sin romper el workflow.
# curse-id: 000000
# wago-id: aBcDeF

# Skip the alternative "no library" variant — this addon ships no libs.
enable-nolib-creation: no

# Use the existing CHANGELOG.md instead of auto-generating one from commits.
manual-changelog: CHANGELOG.md

# Exclude dev artifacts from the released zip.
ignore:
  - .github
  - .gitignore
  - .pkgmeta
  - Build-Package.ps1
  - dist
